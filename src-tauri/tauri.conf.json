{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Hostlyy",
  "version": "1.3.6",
  "identifier": "com.hostly.switcher",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:17749",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Hostlyy",
        "width": 800,
        "height": 600,
        "visible": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/cn07115/Hostlyy/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQwMzlBN0M3NkU1MEE5NjAKUldSZ3FWQnV4NmM1MEsrOU9rSTRCeUVldndWVzhSZUdNTDkrb3ZLK2FtenRRQkFNVzc5eWMwM2EK",
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
